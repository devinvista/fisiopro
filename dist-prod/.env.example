# =============================================================================
# FisioGest Pro — variáveis de ambiente
# =============================================================================
# Copie este arquivo para `.env` e preencha com valores reais.
# NUNCA commite o `.env` (já está no .gitignore).
#
# Em produção (Replit Deploy) configure essas variáveis no painel de Secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Núcleo (obrigatórias)
# -----------------------------------------------------------------------------

# String de conexão PostgreSQL (Neon, Supabase, RDS, etc.)
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# Chave secreta para assinatura de JWT — gere com:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-with-a-long-random-string

# Ambiente de execução: development | production | test
NODE_ENV=development

# -----------------------------------------------------------------------------
# CORS / rede (produção)
# -----------------------------------------------------------------------------

# URL pública do frontend autorizada a chamar a API.
# Em desenvolvimento pode ficar vazio (proxy do Vite).
CORS_ORIGIN=https://seu-dominio.replit.app

# Porta do api-server. Em Replit é injetada automaticamente — deixe vazio.
# PORT=8080

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------

# Nível de log do pino: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Cloudinary (upload de fotos de pacientes / atestados)
# -----------------------------------------------------------------------------
# Use a URL única (CLOUDINARY_URL) OU as três variáveis separadas.
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# -----------------------------------------------------------------------------
# Observabilidade (opcional — Sentry)
# -----------------------------------------------------------------------------

# Backend
SENTRY_DSN_BACKEND=
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Frontend (Vite — qualquer variável exposta ao client deve começar com VITE_)
VITE_SENTRY_DSN=
VITE_SENTRY_RELEASE=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
