# =============================================================================
# FisioGest Pro — variáveis de ambiente
# =============================================================================
# Copie este arquivo para `.env` e preencha com valores reais.
# NUNCA commite o `.env` (já está no .gitignore).
#
# Em produção (Replit Deploy) configure essas variáveis no painel de Secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Núcleo (obrigatórias)
# -----------------------------------------------------------------------------

# String de conexão PostgreSQL (Neon, Supabase, RDS, etc.)
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# Chave secreta para assinatura de JWT — gere com:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-with-a-long-random-string

# Ambiente de execução: development | production | test
NODE_ENV=development

# -----------------------------------------------------------------------------
# CORS / rede (produção)
# -----------------------------------------------------------------------------

# URL pública do frontend autorizada a chamar a API.
# Em desenvolvimento pode ficar vazio (proxy do Vite).
CORS_ORIGIN=https://seu-dominio.replit.app

# Porta do api-server. Em Replit é injetada automaticamente — deixe vazio.
# PORT=8080

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------

# Nível de log do pino: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Cloudinary (upload de fotos de pacientes / atestados)
# -----------------------------------------------------------------------------
# Use a URL única (CLOUDINARY_URL) OU as três variáveis separadas.
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# -----------------------------------------------------------------------------
# Observabilidade (opcional — Sentry)
# -----------------------------------------------------------------------------

# Backend
SENTRY_DSN_BACKEND=
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Frontend (Vite — qualquer variável exposta ao client deve começar com VITE_)
VITE_SENTRY_DSN=
VITE_SENTRY_RELEASE=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# -----------------------------------------------------------------------------
# Sprint 1 — Unificação de pacotes recorrentes
# -----------------------------------------------------------------------------
# Origem dos jobs `runBilling` e `runConsolidatedBilling`:
#   "1" (default, cutover Sprint 1): itera em `patient_packages` filtrando por
#       `recurrence_status='ativa'` e `recurrence_type IN ('mensal','faturaConsolidada')`.
#       Vincula `financial_records` via `patient_package_id`.
#   "0" (legado, fallback reversível): itera em `patient_subscriptions` (modo antigo).
#       Manter durante a janela de migração; remover no Sprint 6.
BILLING_FROM_PACKAGES=1

# Espelhamento legado de `patient_subscriptions` ao criar um pacote recorrente
# em `POST /api/patients/:patientId/packages`:
#   "1": cria também a linha em `patient_subscriptions` (compat com clientes/jobs antigos).
#   "0" (default, cutover Sprint 1): NÃO cria espelho — toda recorrência vive em `patient_packages`.
LEGACY_AUTO_SUBSCRIPTION=0
